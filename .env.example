# NexPorta – environment configuration
# Copy to .env and edit as needed:  cp .env.example .env

# Port the dashboard is exposed on (default: 8199)
# PORT=8199

# Debounce delay in ms before re-indexing after a file change (default: 1000)
# DEBOUNCE_MS=1000

# Password to protect folder creation and file upload APIs (default: secure random ephemeral password)
# API_PASSWORD=nexporta_secret_pass

# Duration in minutes that the password session remains valid (default: 30)
# SESSION_TIMEOUT_MINUTES=30

# CORS allowed origin (default: *, set specific domain like https://inhaus.atts.one to restrict)
# ALLOWED_CORS_ORIGIN=*
